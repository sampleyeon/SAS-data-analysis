# --- 그 다음 아래 교차 검증 코드를 실행하세요 ---
from sklearn.model_selection import StratifiedKFold
from sklearn.metrics import roc_auc_score, mean_squared_error

skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=100)
auc_scores, rmse_scores = [], []

for fold, (train_idx, val_idx) in enumerate(skf.split(X_final, y_churn)):
    X_tr, X_vl = X_final.iloc[train_idx], X_final.iloc[val_idx]
    yc_tr, yc_vl = y_churn.iloc[train_idx], y_churn.iloc[val_idx]
    yl_tr, yl_vl = y_ltv.iloc[train_idx], y_ltv.iloc[val_idx]

    # --- [Churn 전문가 1: LGBM] ---
    m_lgb_c = lgb.LGBMClassifier(**CHURN_PARAMS)
    m_lgb_c.fit(X_tr, yc_tr, eval_set=[(X_vl, yc_vl)], 
               callbacks=[lgb.early_stopping(150, verbose=False), lgb.log_evaluation(-1)])
    prob_lgb = m_lgb_c.predict_proba(X_vl)[:, 1]

    # --- [Churn 전문가 2: XGBoost] ---
    # fit 안의 early_stopping_rounds 옵션을 위쪽 파라미터로 옮겼으므로 에러 안 날 거예요!
    m_xgb_c = xgb.XGBClassifier(**CHURN_XGB_PARAMS)
    m_xgb_c.fit(X_tr, yc_tr, eval_set=[(X_vl, yc_vl)], verbose=False)
    prob_xgb = m_xgb_c.predict_proba(X_vl)[:, 1]

    # --- [의견 반반 섞기] ---
    ensemble_prob = (prob_lgb * 0.5) + (prob_xgb * 0.5)
    auc = roc_auc_score(yc_vl, ensemble_prob)
    auc_scores.append(auc)

    # --- [LTV 모델 학습] ---
    lm = lgb.LGBMRegressor(**LTV_PARAMS).fit(X_tr, yl_tr, eval_set=[(X_vl, yl_vl)], 
                                            callbacks=[lgb.early_stopping(150, verbose=False), lgb.log_evaluation(-1)])
    ltv_pred = np.maximum(lm.predict(X_vl), 0) ** 2
    rmse = np.sqrt(mean_squared_error(df['target_ltv'].iloc[val_idx], ltv_pred))
    rmse_scores.append(rmse)

    print(f"Fold {fold+1} | 앙상블 AUC: {auc:.4f} | LTV RMSE: {rmse:,.0f}")

    # --- [수정된 스텝 16 마지막 부분] ---

# 1. 평균 AUC와 평균 RMSE 계산
avg_auc = np.mean(auc_scores)
avg_rmse = np.mean(rmse_scores)

# log 안에 들어가는 SE(LTV)는 모델의 예측 오차 수준(avg_rmse)을 대입합니다.
# 분모가 0이 되는 것을 방지하기 위해 보통 RMSE 값을 활용해요.

score = 0.5 * avg_auc + 0.5 * (1 / (1 + np.log(avg_rmse)))

print(f"\n{'='*45}")
print(f"공식 기준 최종 결과")
print(f"{'='*45}")
print(f"평균 AUC (Churn) : {avg_auc:.4f}")
print(f"평균 RMSE (LTV)   : {avg_rmse:,.0f}")
print(f"최종 통합 Score   : {score:.5f}")
print(f"{'='*45}")

