# --- 21. 최종 앙상블 예측 및 성능 모니터링 ---
churn_preds = np.zeros(len(test_df))
ltv_preds   = np.zeros(len(test_df))
X_test_final = test_df[X_final.columns]
n_folds = 5

for fold, (train_idx, val_idx) in enumerate(skf.split(X_final, y_churn)):
    # 데이터 준비
    X_tr, X_vl = X_final.iloc[train_idx], X_final.iloc[val_idx]
    yc_tr, yc_vl = y_churn.iloc[train_idx], y_churn.iloc[val_idx]
    yl_tr, yl_vl = y_ltv.iloc[train_idx], y_ltv.iloc[val_idx]

    # [1] Churn 앙상블 전문가 학습
    c_lgb = lgb.LGBMClassifier(**CHURN_PARAMS)
    c_lgb.fit(X_tr, yc_tr, eval_set=[(X_vl, yc_vl)], callbacks=[lgb.early_stopping(150, verbose=False)])
    
    c_xgb = xgb.XGBClassifier(**CHURN_XGB_PARAMS)
    c_xgb.fit(X_tr, yc_tr, eval_set=[(X_vl, yc_vl)], verbose=False)
    
    # 테스트 데이터 예측 (앙상블)
    fold_churn_prob = (c_lgb.predict_proba(X_test_final)[:, 1] * 0.5) + (c_xgb.predict_proba(X_test_final)[:, 1] * 0.5)
    churn_preds += fold_churn_prob / n_folds

    # [2] LTV 전문가 학습
    l_m = lgb.LGBMRegressor(**LTV_PARAMS)
    l_m.fit(X_tr, yl_tr, eval_set=[(X_vl, yl_vl)], callbacks=[lgb.early_stopping(150, verbose=False)])
    
    # 테스트 데이터 예측 (역변환)
    ltv_preds += np.maximum(l_m.predict(X_test_final), 0) ** 2 / n_folds

    # --- 각 Fold의 검증 성능 계산 ---
    # Churn 검증 (앙상블)
    fold_vl_ensemble = (c_lgb.predict_proba(X_vl)[:, 1] * 0.5) + (c_xgb.predict_proba(X_vl)[:, 1] * 0.5)
    fold_auc = roc_auc_score(yc_vl, fold_vl_ensemble)
    
    # LTV 검증 (역변환)
    fold_ltv_pred = np.maximum(l_m.predict(X_vl), 0) ** 2
    fold_rmse = np.sqrt(mean_squared_error(df.loc[val_idx, 'target_ltv'], fold_ltv_pred))

    # 결과 출력
    print(f"Fold {fold+1}/{n_folds} 완료 | AUC: {fold_auc:.4f} | RMSE: {fold_rmse:,.0f}")

print("\n전체 Fold 앙상블 및 예측 완료!")

