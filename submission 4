import xgboost as xgb

# --- [1] Churn 전문가 1: LightGBM (기존과 동일) ---
churn_model_lgb = lgb.LGBMClassifier(
    n_estimators     = 1000,
    learning_rate    = 0.05,
    num_leaves       = 31,
    scale_pos_weight = 9,
    random_state     = 100,
    verbose          = -1
)

churn_model_lgb.fit(
    X_train, y_churn_train,
    eval_set  = [(X_val, y_churn_val)],
    callbacks = [lgb.early_stopping(50), lgb.log_evaluation(100)]
)

# --- [2] Churn 전문가 2: XGBoost (에러 수정 부분!) ---
